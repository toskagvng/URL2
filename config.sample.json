    "useSsl": true,
    "username": "ton-adresse@gmail.com",
    "passwordEnv": "URL_WATCH_SMTP_PASSWORD",
    "from": "ton-adresse@gmail.com",
    "to": [
      "ton-adresse@gmail.com"
    ]
  }
}
